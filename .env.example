# GitHub
# GitHub Personal Access Token for repository operations
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=your_github_token_here

# Vercel
# Vercel Access Token for creating deployments
# Create at: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# Vercel Team ID (optional)
# Required only for team accounts
# Find in Vercel project settings
VERCEL_TEAM_ID=your_vercel_team_id_here

# Vercel Webhook Secret (optional)
# Used to verify webhook requests from Vercel
# Configure in Vercel project webhook settings
VERCEL_WEBHOOK_SECRET=your_webhook_secret_here

# Database
# Database connection URL
# For SQLite: "file:./openclaw.db"
# For PostgreSQL: "postgresql://user:password@localhost:5432/dbname"
DATABASE_URL="file:./openclaw.db"

# Application
# Application URL (used for callbacks and webhooks)
APP_URL=http://localhost:3000

# Session Secret
# Used for session encryption (generate a random string)
SESSION_SECRET=your_random_session_secret_here
