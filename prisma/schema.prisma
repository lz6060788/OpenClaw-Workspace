// Prisma schema for OpenClaw Workspace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 任务模型
model Task {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("pending") // pending, running, paused, completed, failed
  priority    Int      @default(0)
  owner       String?
  context     String?  // 独立上下文数据（JSON）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?
  
  // 关联的日志
  logs        TaskLog[]
  
  // 关联的步骤
  steps       TaskStep[]
}

// 任务日志
model TaskLog {
  id        String   @id @default(uuid())
  taskId    String
  content   String
  type      String   @default("info") // info, output, error
  timestamp DateTime @default(now())
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// 任务步骤（子任务）
model TaskStep {
  id          String   @id @default(uuid())
  taskId      String
  name        String
  description String?
  status      String   @default("pending")
  order       Int      @default(0)
  result      String?  // JSON 格式的结果
  createdAt   DateTime @default(now())
  completedAt DateTime?
  
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
